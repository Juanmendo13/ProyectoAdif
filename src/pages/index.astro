---
import fs from 'node:fs';
import path from 'node:path';
import '../styles/global.css'; // <--- AÑADE ESTA LÍNEA AQUÍ

// 1. Definimos la ruta física real hacia la subcarpeta de consignas
const docsDir = path.join(process.cwd(), 'public', 'docs', 'Consignas finales');
let rawFiles: string[] = [];

if (fs.existsSync(docsDir)) {
  // Buscamos de forma recursiva en pe-17, pe-24, pe-26...
  const allFiles = fs.readdirSync(docsDir, { recursive: true }) as string[];
  // Nos quedamos únicamente con los ficheros PDF
  rawFiles = allFiles.filter(file => file.endsWith('.pdf'));
}

// 2. Procesamos los archivos para extraer la información y armar las tarjetas de la interfaz
const estaciones = rawFiles.map((filePath) => {
  // Normalizamos las barras de las rutas para entornos Linux/Vercel (cambiar \ por /)
  const normalizedPath = filePath.replace(/\\/g, '/');
  
  // Extraemos el nombre del archivo final (ej. "01_El Priorato.pdf")
  const fileName = normalizedPath.split('/').pop() || '';
  
  // Limpiamos la extensión y el prefijo numérico (ej. "01_El Priorato" -> "El Priorato")
  const cleanName = fileName
    .replace('.pdf', '')
    .replace(/^\d+_/,'')
    .replace(/_/g, ' ');

  // Clasificamos si es una subestación (S/E) o un esquema de estación convencional
  const esSubestacion = fileName.toLowerCase().includes('s.e.') || fileName.toLowerCase().includes('subestacion');

  return {
    nombre: cleanName,
    // La URL pública web para que el navegador descargue el archivo desde la carpeta public
    url: `/docs/Consignas finales/${normalizedPath}`,
    esSubestacion,
    // Guardamos el nombre de la carpeta (ej. pe-17) por si quieres agrupar por líneas en el diseño
    linea: normalizedPath.split('/')[0] 
  };
});
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Red Convencional Sur - Visor de Consignas</title>
  </head>
  <body class="bg-slate-900 text-slate-100 min-h-screen font-sans flex flex-col justify-between">
    
    <!-- CABECERA CORPORATIVA (Estilo Adif) -->
    <header class="bg-slate-950 border-b-4 border-emerald-600 shadow-xl p-4">
      <div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-4">
          <!-- Logo de Adif -->
          <div class="bg-emerald-600 text-white font-black tracking-tighter px-4 py-2 rounded text-xl shadow-inner">
            adif
          </div>
          <div>
            <h1 class="text-xl font-bold tracking-wide">Red Convencional Sur</h1>
            <p class="text-xs text-slate-400 font-mono">Visor Digital de Consignas de Electrificación</p>
          </div>
        </div>
        <div class="flex items-center gap-2 bg-slate-900 px-3 py-1.5 rounded border border-slate-800 text-xs font-mono">
          <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
          <span class="text-slate-400">Acceso Técnico Profesional | </span>
          <span class="text-emerald-400 font-semibold">Sistema Sincronizado</span>
        </div>
      </div>
    </header>

    <!-- CONTENIDO PRINCIPAL -->
    <main class="max-w-7xl mx-auto p-6 w-full flex-grow">
      
      <!-- Panel Informativo Inicial -->
      <section class="bg-slate-950 border border-slate-850 p-6 rounded-xl mb-8 shadow-md">
        <h2 class="text-lg font-bold text-emerald-400 mb-2">Repositorio Oficial de Esquemas Ferroviarios</h2>
        <p class="text-sm text-slate-400 leading-relaxed max-w-4xl">
          Los documentos se cargan y ordenan dinámicamente según el quilometraje de la infraestructura ferroviaria local. 
          Las subestaciones de tracción y las estaciones base comparten el mismo bloque de visualización técnica.
        </p>
      </section>

      <!-- REJILLA DE ESTACIONES Y SUBESTACIONES -->
      {estaciones.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {estaciones.map((estacion) => (
            <div class="bg-slate-950 border border-slate-850 rounded-xl p-5 hover:border-emerald-600/50 transition-all duration-200 flex flex-col justify-between group shadow-sm">
              <div class="mb-4">
                <div class="flex justify-between items-start mb-2 gap-2">
                  <span class="text-[10px] font-mono uppercase bg-slate-900 border border-slate-800 text-slate-400 px-2 py-0.5 rounded">
                    {estacion.linea}
                  </span>
                  <span class={`text-[10px] font-mono font-bold uppercase px-2 py-0.5 rounded border ${
                    estacion.esSubestacion 
                      ? 'bg-amber-950/40 text-amber-400 border-amber-900/50' 
                      : 'bg-sky-950/40 text-sky-400 border-sky-900/50'
                  }`}>
                    {estacion.esSubestacion ? 'Subestación (S/E)' : 'Esquema Estación'}
                  </span>
                </div>
                <h3 class="text-base font-bold text-slate-200 group-hover:text-emerald-400 transition-colors duration-150">
                  {estacion.nombre}
                </h3>
              </div>
              
              <a 
                href={estacion.url} 
                target="_blank" 
                rel="noreferrer"
                class="w-full text-center bg-slate-900 hover:bg-emerald-600 text-slate-300 hover:text-white font-medium text-xs py-2.5 px-4 rounded-lg border border-slate-800 hover:border-emerald-500 transition-all duration-200 shadow-sm flex items-center justify-center gap-1.5"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                </svg>
                Abrir Documentación Técnica
              </a>
            </div>
          ))}
        </div>
      ) : (
        /* Fallback seguro por si ocurre algún fallo en las rutas */
        <div class="text-center py-12 bg-slate-950 border border-slate-850 rounded-xl border-dashed">
          <p class="text-slate-400 text-sm">No se han encontrado consignas cargadas en este sector.</p>
        </div>
      )}
    </main>

    <!-- PIE DE PÁGINA -->
    <footer class="bg-slate-950 border-t border-slate-850 p-4 text-[11px] font-mono text-slate-500">
      <div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2">
        <p>&copy; 2026 Adif - Jefatura de Mantenimiento de la Red Convencional Sur.</p>
        <p class="text-slate-600 uppercase tracking-wider">Documentación Técnica de Uso Interno Reservado</p>
      </div>
    </footer>

  </body>
</html>