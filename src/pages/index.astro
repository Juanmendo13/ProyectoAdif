---
import '../styles/global.css';
import fs from 'fs';
import path from 'path';
import lineasData from '../data/lineas.json';

// 1. Ruta física del enlace simbólico
const docsDir = path.join(process.cwd(), 'public', 'docs');

// 2. Mapeamos los datos del JSON para indexar los metadatos de las líneas por su ID
const infoLineas = {};
lineasData.forEach(l => {
  infoLineas[l.id] = {
    codigo: l.codigo,
    nombre: l.nombre,
    color: l.color
  };
});

let lineasProcesadas = [];

if (fs.existsSync(docsDir)) {
  // Leemos las carpetas dentro de public/docs (pe-17, pe-24, pe-26)
  const carpetas = fs.readdirSync(docsDir).filter(f => f.startsWith('pe-'));

  lineasProcesadas = carpetas.map(carpeta => {
    const rutaCarpeta = path.join(docsDir, carpeta);
    // Leemos los archivos físicos reales del directorio
    const archivos = fs.readdirSync(rutaCarpeta).filter(f => f.endsWith('.pdf'));
    
    // Alfabéticamente '01_...', '02_...' ya garantiza el orden kilométrico real de las vías
    archivos.sort();

    const estacionesMap = new Map();

    archivos.forEach(archivo => {
      const nombreSinExt = archivo.replace('.pdf', '');
      
      // Extraemos el número de orden del principio (ej: "01" de "01_El Priorato")
      const matchPrefijo = nombreSinExt.match(/^(\d+)_/);
      const numOrden = matchPrefijo ? parseInt(matchPrefijo[1], 10) : 99;

      // Quitamos el prefijo numérico para trabajar con el nombre limpio
      let nombreLimpio = nombreSinExt.replace(/^\d+_+/, '').trim();
      
      // Comprobamos si es una subestación eléctrica (S/E o Subestacion)
      const esSubestacion = nombreLimpio.toLowerCase().includes('_subestacion') || nombreLimpio.toLowerCase().includes(' s_e');
      
      // Obtenemos el nombre base de la estación física unificada
      const estacionBase = nombreLimpio
        .replace(/_Subestacion/i, '')
        .replace(/\s+S\/E\.?/i, '')
        .replace(/_S_E/i, '')
        .trim();

      if (!estacionesMap.has(estacionBase)) {
        estacionesMap.set(estacionBase, {
          nombre: estacionBase,
          planoEstacion: null,
          planoSubestacion: null,
          numOrden: numOrden
        });
      }

      const item = estacionesMap.get(estacionBase);
      // El enlace que se descarga usará la ruta real del archivo físico del explorador
      const urlEnlace = `/docs/${carpeta}/${archivo}`;

      if (esSubestacion) {
        item.planoSubestacion = urlEnlace;
      } else {
        item.planoEstacion = urlEnlace;
      }
    });

    // Ordenamos el array final basándonos en los prefijos numéricos de tus archivos
    const estacionesOrdenadas = Array.from(estacionesMap.values()).sort((a, b) => a.numOrden - b.numOrden);

    return {
      id: carpeta,
      codigo: infoLineas[carpeta]?.codigo || carpeta.toUpperCase(),
      nombre: infoLineas[carpeta]?.nombre || 'Línea Ferroviaria',
      color: infoLineas[carpeta]?.color || '#1C2D37',
      estaciones: estacionesOrdenadas
    };
  });
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sistema de Gestión Documental - Adif Red Convencional</title>
  </head>
  <body class="bg-[#F4F6F5] text-[#1C2D37] font-sans min-h-screen flex flex-col">
    
    <!-- BARRA SUPERIOR CORPORATIVA -->
    <header class="bg-[#1C2D37] text-white shadow-md border-b-4 border-[#008A4A]">
      <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-3">
          <div class="bg-[#008A4A] text-white font-black px-3 py-1.5 text-xl tracking-wider rounded">adif</div>
          <div>
            <h1 class="text-lg font-bold tracking-tight">Red Convencional Sur</h1>
            <p class="text-xs text-gray-400 font-mono">Visor Digital de Consignas de Electrificación</p>
          </div>
        </div>
        <div class="text-right hidden md:block">
          <p class="text-xs text-gray-400">Acceso Técnico Profesional</p>
          <p class="text-xs font-medium text-emerald-400 flex items-center gap-1 justify-end">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span> Sistema Sincronizado
          </p>
        </div>
      </div>
    </header>

    <!-- CONTENIDO PRINCIPAL -->
    <main class="flex-1 max-w-7xl w-full mx-auto px-6 py-10">
      
      <div class="mb-10 bg-white p-6 rounded-xl shadow-sm border border-gray-200">
        <h2 class="text-xl font-bold mb-2 text-gray-800">Repositorio Oficial de Esquemas Ferroviarios</h2>
        <p class="text-sm text-gray-600 max-w-3xl">
          Los documentos se cargan y ordenan dinámicamente según el quilometraje de la infraestructura ferroviaria local. Las subestaciones y las estaciones base comparten el mismo bloque de visualización técnica.
        </p>
      </div>

      <!-- BUCLE DE LÍNEAS -->
      <div class="space-y-12">
        {lineasProcesadas.map((linea) => (
          <section class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <!-- Cabecera de la Línea -->
            <div class="p-5 text-white flex flex-col sm:flex-row sm:items-center justify-between gap-2" style={`background-color: ${linea.color};`}>
              <div class="flex items-baseline gap-3">
                <span class="font-mono bg-white/20 px-2 py-0.5 rounded text-sm font-bold tracking-wider">{linea.codigo}</span>
                <h3 class="text-xl font-bold tracking-tight">{linea.nombre}</h3>
              </div>
              <span class="text-xs font-mono opacity-90">{linea.estaciones.length} Elementos</span>
            </div>

            <!-- Grid de tarjetas de Estaciones -->
            <div class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 bg-gray-50/50">
              {linea.estaciones.map((estacion) => (
                <div class="bg-white p-4 rounded-lg border border-gray-200 shadow-sm hover:shadow-md transition-all flex flex-col justify-between group">
                  <div class="mb-4">
                    <div class="flex items-start justify-between gap-2">
                      <h4 class="font-bold text-gray-800 text-base leading-tight group-hover:text-[#008A4A] transition-colors">
                        {estacion.nombre}
                      </h4>
                      <span class="text-[10px] font-mono text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded">
                        ID {estacion.numOrden}
                      </span>
                    </div>
                  </div>

                  <!-- Botones de Acción utilizando las rutas de tus archivos reales -->
                  <div class="grid grid-cols-1 gap-2">
                    {estacion.planoEstacion ? (
                      <a 
                        href={estacion.planoEstacion} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="inline-flex items-center justify-center gap-2 text-xs bg-[#1C2D37] hover:bg-[#008A4A] text-white font-semibold py-2.5 px-3 rounded shadow-sm transition-all"
                      >
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        Esquema de Vías
                      </a>
                    ) : (
                      <div class="text-center text-[11px] text-gray-400 bg-gray-50 py-2 rounded border border-dashed border-gray-200 font-medium">
                        Sin plano de vías propio
                      </div>
                    )}

                    {estacion.planoSubestacion && (
                      <a 
                        href={estacion.planoSubestacion} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="inline-flex items-center justify-center gap-2 text-xs bg-white hover:bg-emerald-50 text-emerald-700 border border-emerald-600 font-bold py-2.5 px-3 rounded shadow-sm transition-all"
                      >
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                        Consigna de Subestación
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </section>
        ))}
      </div>
    </main>

    <!-- PIE DE PÁGINA -->
    <footer class="bg-[#1C2D37] text-gray-400 text-xs py-6 border-t border-gray-800 font-mono mt-16">
      <div class="max-w-7xl mx-auto px-6 flex flex-col sm:flex-row justify-between items-center gap-2">
        <p>© 2026 Adif - Jefatura de Mantenimiento de la Red Convencional Sur.</p>
        <p class="text-[11px] text-gray-500">Documentación Técnica de Uso Interno Reservado</p>
      </div>
    </footer>

  </body>
</html>