---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Portal de Consignas - Adif Electrificación</title>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen font-sans flex flex-col justify-center items-center p-6">
    
    <div class="max-w-4xl w-full text-center mb-12">
      <span class="text-xs font-mono tracking-widest uppercase bg-emerald-950 text-emerald-400 border border-emerald-800 px-3 py-1 rounded-full">
        Red Convencional Sur
      </span>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight text-white mt-4 mb-2">
        Visor de Consignas de Electrificación
      </h1>
      <p class="text-slate-400 text-base md:text-lg">
        Selecciona una línea ferroviaria para inspeccionar su esquema y subestaciones asociadas.
      </p>
    </div>

    <!-- PANEL DE SELECCIÓN DE LÍNEAS -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl w-full">
      
      <!-- LINEA PE-17 -->
      <a href="/pe-17" class="group bg-slate-900 border border-slate-800 hover:border-emerald-500/50 rounded-2xl p-8 flex flex-col justify-between shadow-xl transition-all duration-300 hover:-translate-y-1">
        <div>
          <div class="w-12 h-12 rounded-xl bg-emerald-950 border border-emerald-800 flex items-center justify-center text-emerald-400 font-bold mb-6 group-hover:bg-emerald-900/50">
            17
          </div>
          <h2 class="text-2xl font-bold text-white mb-2 group-hover:text-emerald-400 transition-colors">P.E. 17</h2>
          <p class="text-slate-400 text-sm leading-relaxed">
            Línea de Madrid a Sevilla (Tramo El Priorato - Sevilla Santa Justa).
          </p>
        </div>
        <div class="mt-8 flex items-center text-xs font-semibold text-emerald-400 gap-1 opacity-60 group-hover:opacity-100 transition-opacity">
          Entrar al mapa 
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </div>
      </a>

      <!-- LINEA PE-24 -->
      <a href="/pe-24" class="group bg-slate-900 border border-slate-800 hover:border-sky-500/50 rounded-2xl p-8 flex flex-col justify-between shadow-xl transition-all duration-300 hover:-translate-y-1">
        <div>
          <div class="w-12 h-12 rounded-xl bg-sky-950 border border-sky-800 flex items-center justify-center text-sky-400 font-bold mb-6 group-hover:bg-sky-900/50">
            24
          </div>
          <h2 class="text-2xl font-bold text-white mb-2 group-hover:text-sky-400 transition-colors">P.E. 24</h2>
          <p class="text-slate-400 text-sm leading-relaxed">
            Línea de Sevilla a Cádiz (Esquema secuencial de estaciones y SS/EE).
          </p>
        </div>
        <div class="mt-8 flex items-center text-xs font-semibold text-sky-400 gap-1 opacity-60 group-hover:opacity-100 transition-opacity">
          Entrar al mapa 
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </div>
      </a>

      <!-- LINEA PE-26 -->
      <a href="/pe-26" class="group bg-slate-900 border border-slate-800 hover:border-amber-500/50 rounded-2xl p-8 flex flex-col justify-between shadow-xl transition-all duration-300 hover:-translate-y-1">
        <div>
          <div class="w-12 h-12 rounded-xl bg-amber-950 border border-amber-800 flex items-center justify-center text-amber-400 font-bold mb-6 group-hover:bg-amber-900/50">
            26
          </div>
          <h2 class="text-2xl font-bold text-white mb-2 group-hover:text-amber-400 transition-colors">P.E. 26</h2>
          <p class="text-slate-400 text-sm leading-relaxed">
            Línea de Bifurcación Los Naranjos a Huelva.
          </p>
        </div>
        <div class="mt-8 flex items-center text-xs font-semibold text-amber-400 gap-1 opacity-60 group-hover:opacity-100 transition-opacity">
          Entrar al mapa 
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </div>
      </a>

    </div>

  </body>
</html>