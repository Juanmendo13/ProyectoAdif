---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="es" class="h-full">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Visor de Consignas de Electrificación - Inicio</title>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col font-sans">
    
    <!-- HEADER INSTITUCIONAL (Sin línea activa para ocultar el botón volver aquí) -->
    <Header />

    <!-- CONTENIDO PRINCIPAL ORIGINAL -->
    <main class="max-w-[1600px] mx-auto px-8 py-16 flex-1 flex flex-col justify-center items-center w-full">
      
      <div class="text-center mb-12">
        <span class="text-xs font-mono uppercase bg-emerald-950/80 text-emerald-400 border border-emerald-800/60 px-3 py-1 rounded-full font-semibold tracking-wider">
          Red Convencional Sur
        </span>
        <h1 class="text-5xl font-black tracking-tight text-white mt-4 mb-3">
          Visor de Consignas de Electrificación
        </h1>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          Selecciona una línea ferroviaria para inspeccionar su esquema y subestaciones asociadas.
        </p>
      </div>

      <!-- REJILLA DE TARJETAS EXACTA A TU DISEÑO ORIGINAL -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full max-w-6xl mt-4">
        
        <!-- P.E. 17 -->
        <div class="bg-slate-900/60 border border-slate-800/80 rounded-3xl p-8 flex flex-col justify-between hover:border-emerald-500/40 transition-all duration-300 group shadow-xl">
          <div>
            <div class="w-12 h-12 rounded-xl bg-emerald-950/50 border border-emerald-800/50 flex items-center justify-center font-mono font-bold text-emerald-400 text-lg mb-6">
              17
            </div>
            <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">P.E. 17</h2>
            <p class="text-slate-400 text-sm leading-relaxed mb-8">
              Línea de Madrid a Sevilla (Tramo El Priorato - Sevilla Santa Justa).
            </p>
          </div>
          <a href="/pe-17" class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-400 group-hover:text-emerald-300 transition-colors">
            Entrar al mapa 
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>

        <!-- P.E. 24 -->
        <div class="bg-slate-900/60 border border-slate-800/80 rounded-3xl p-8 flex flex-col justify-between hover:border-cyan-500/40 transition-all duration-300 group shadow-xl">
          <div>
            <div class="w-12 h-12 rounded-xl bg-cyan-950/50 border border-cyan-800/50 flex items-center justify-center font-mono font-bold text-cyan-400 text-lg mb-6">
              24
            </div>
            <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">P.E. 24</h2>
            <p class="text-slate-400 text-sm leading-relaxed mb-8">
              Línea de Sevilla a Cádiz (Esquema secuencial de estaciones y SS/EE).
            </p>
          </div>
          <a href="/pe-24" class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-400 group-hover:text-cyan-300 transition-colors">
            Entrar al mapa 
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>

        <!-- P.E. 26 -->
        <div class="bg-slate-900/60 border border-slate-800/80 rounded-3xl p-8 flex flex-col justify-between hover:border-amber-500/40 transition-all duration-300 group shadow-xl">
          <div>
            <div class="w-12 h-12 rounded-xl bg-amber-950/50 border border-amber-800/50 flex items-center justify-center font-mono font-bold text-amber-500 text-lg mb-6">
              26
            </div>
            <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">P.E. 26</h2>
            <p class="text-slate-400 text-sm leading-relaxed mb-8">
              Línea de Bifurcación Los Naranjos a Huelva.
            </p>
          </div>
          <a href="/pe-26" class="inline-flex items-center gap-2 text-sm font-semibold text-amber-500 group-hover:text-amber-400 transition-colors">
            Entrar al mapa 
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>

      </div>
    </main>

    <!-- FOOTER INSTITUCIONAL -->
    <Footer />
  </body>
</html>