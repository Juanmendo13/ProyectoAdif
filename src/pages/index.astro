---
import fs from 'node:fs';
import path from 'node:path';
import '../styles/global.css';

// 1. Ruta física hacia la subcarpeta de consignas
const docsDir = path.join(process.cwd(), 'public', 'docs', 'Consignas finales');
let rawFiles: string[] = [];

if (fs.existsSync(docsDir)) {
  // Buscamos de forma recursiva
  const allFiles = fs.readdirSync(docsDir, { recursive: true }) as string[];
  // Filtramos por PDF
  rawFiles = allFiles.filter(file => file.endsWith('.pdf'));
}

// 2. Procesamos y aplanamos la lista de archivos
const todasLasEstaciones = rawFiles.map((filePath) => {
  // Normalizamos las barras de las rutas para entornos Linux/Vercel (cambiar \ por /)
  const normalizedPath = filePath.replace(/\\/g, '/');
  
  // Extraemos el nombre del archivo final (ej. "01_El Priorato.pdf")
  const fileName = normalizedPath.split('/').pop() || '';
  
  // Limpiamos el prefijo numérico (ej. "01_El Priorato" -> "El Priorato")
  const cleanName = fileName
    .replace('.pdf', '')
    .replace(/^\d+_/,'')
    .replace(/_/g, ' ');

  // Clasificamos si es una subestación o estación
  const esSubestacion = fileName.toLowerCase().includes('s.e.') || fileName.toLowerCase().includes('subestacion');

  // Identificamos la línea por el nombre de la carpeta (ej. pe-17)
  const linea = normalizedPath.split('/')[0].toUpperCase();

  return {
    nombre: cleanName,
    url: `/docs/Consignas finales/${normalizedPath}`,
    esSubestacion,
    linea
  };
});

// 3. NUEVA LÓGICA: Agrupamos las estaciones por código de línea
// Esto crea un objeto tipo: { 'PE-17': [...estaciones], 'PE-24': [...estaciones] }
const estacionesAgrupadas = todasLasEstaciones.reduce((agrupacion, estacion) => {
  const linea = estacion.linea;
  if (!agrupacion[linea]) {
    agrupacion[linea] = [];
  }
  agrupacion[linea].push(estacion);
  return agrupacion;
}, {} as Record<string, typeof todasLasEstaciones>);

// 4. Obtenemos los códigos de línea ordenados alfabéticamente (ej. PE-17, PE-24)
const codigosDeLinea = Object.keys(estacionesAgrupadas).sort();
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Visor de Consignas - Agrupado por Línea</title>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen font-sans">
    
    <!-- CONTENIDO PRINCIPAL -->
    <main class="max-w-[1900px] mx-auto p-12 w-full">
      
      {codigosDeLinea.length > 0 ? (
        // Iteramos sobre cada código de línea (PE-17, PE-24, etc.)
        codigosDeLinea.map((codigoLinea) => (
          // Sección separada para cada línea con margen inferior
          <section class="mb-16 last:mb-0">
            
            <!-- TÍTULO DE LA DIVISIÓN DE LÍNEA -->
            <div class="flex items-center gap-4 mb-8 border-b border-slate-800 pb-4">
              <span class="text-xs font-mono uppercase bg-emerald-950 text-emerald-300 border border-emerald-800 px-3 py-1 rounded">
                {codigoLinea}
              </span>
              <h2 class="text-3xl font-bold tracking-tight text-slate-100">
                Consignas {codigoLinea}
              </h2>
              <span class="text-sm font-mono text-slate-600">
                ({estacionesAgrupadas[codigoLinea].length} elementos)
              </span>
            </div>

            <!-- REJILLA DE ESTACIONES PARA ESTA LÍNEA ESPECÍFICA -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
              {estacionesAgrupadas[codigoLinea].map((estacion) => (
                // Diseño de tarjeta (mismo estilo que image_12.png)
                <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 flex flex-col justify-between shadow-lg">
                  <div class="mb-6">
                    <div class="flex justify-between items-start mb-3 gap-2">
                      <span class="text-xs font-mono uppercase bg-slate-800 text-slate-400 border border-slate-700 px-2.5 py-1 rounded">
                        {estacion.linea}
                      </span>
                      <span class={`text-xs font-mono font-bold uppercase px-2.5 py-1 rounded border ${
                        estacion.esSubestacion 
                          ? 'bg-amber-950/50 text-amber-300 border-amber-900/60' 
                          : 'bg-sky-950/50 text-sky-300 border-sky-900/60'
                      }`}>
                        {estacion.esSubestacion ? 'Subestación (S/E)' : 'Esquema Estación'}
                      </span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-100 leading-tight">
                      {estacion.nombre}
                    </h3>
                  </div>
                  
                  <a 
                    href={estacion.url} 
                    target="_blank" 
                    rel="noreferrer"
                    class="w-full text-center bg-slate-800 hover:bg-slate-700 text-slate-200 font-semibold text-sm py-3 px-5 rounded-lg border border-slate-700 hover:border-slate-600 transition-all duration-150 shadow-sm flex items-center justify-center gap-2"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4.5 h-4.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                    </svg>
                    Abrir Documentación Técnica
                  </a>
                </div>
              ))}
            </div>

          </section>
        ))
      ) : (
        <div class="text-center py-20 bg-slate-900 border-2 border-slate-800 border-dashed rounded-3xl">
          <p class="text-slate-500 text-lg">No se han encontrado consignas cargadas.</p>
        </div>
      )}
    </main>

  </body>
</html>