---
// src/pages/[linea]/[estacion]-3d.astro
import fs from "node:fs";
import path from "node:path";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/global.css";

import { TRAMOS_VIAS } from "../../data/geo-infraestructura.js";

// Función auxiliar idéntica para limpiar de raíz tildes y caracteres especiales
const limpiarString = (str: string) => {
  return str
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "") // Elimina tildes
    .replace(/[^a-z0-9]/g, " ") // Cambia símbolos por espacios
    .replace(/\s+/g, " ") // Colapsa múltiples espacios
    .trim();
};

export function getStaticPaths() {
  const lineas = ["pe-17", "pe-24", "pe-26"];
  const paths = [];

  lineas.forEach((linea) => {
    const tramosDeEstaLinea = TRAMOS_VIAS[linea] || [];
    const estacionesUnicas = [...new Set(tramosDeEstaLinea.flat())];

    estacionesUnicas.forEach((nombre) => {
      const slugEstacion = nombre
        .toLowerCase()
        .replace(/\./g, "")
        .replace(/[\s\-]+/g, "-")
        .replace(/[^a-z0-9\-áéíóúñ]/g, "");

      paths.push({
        params: { linea, estacion: slugEstacion },
        props: { nombreReal: nombre },
      });
    });
  });

  return paths;
}

const { linea, estacion } = Astro.params;
const { nombreReal } = Astro.props;

// ==========================================
// 1. CONTROL DINÁMICO DE CONSIGNAS A
// ==========================================
const pdfLimpio = estacion.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
const docsDirA = path.join(
  process.cwd(),
  "public",
  "docs",
  "ConsignasA",
  linea,
  `${pdfLimpio}.pdf`,
);

const tieneConsignaA = fs.existsSync(docsDirA);
const urlConsignaA = tieneConsignaA
  ? `/docs/ConsignasA/${linea}/${pdfLimpio}.pdf`
  : "#";

// ==========================================
// 2. CONTROL DINÁMICO DE CONSIGNAS ELÉCTRICAS
// ==========================================
const docsDirElec = path.join(
  process.cwd(),
  "public",
  "docs",
  "ConsignasElectricas",
);
let pdfElectricoUrl = null;

if (fs.existsSync(docsDirElec)) {
  const allFiles = fs.readdirSync(docsDirElec, { recursive: true }) as string[];
  const estacionToken = limpiarString(estacion);

  allFiles.forEach((file) => {
    const normPath = file.replace(/\\/g, "/");
    const parts = normPath.split("/");

    if (parts.length > 1 && parts[0].toLowerCase() === linea.toLowerCase()) {
      const fileName = parts[parts.length - 1];
      const fileNameLimpio = limpiarString(fileName);

      if (fileNameLimpio.includes(estacionToken)) {
        pdfElectricoUrl = `/docs/ConsignasElectricas/${normPath}`;
      }
    }
  });
}

const pdfElectrico = pdfElectricoUrl || "#";
const tieneElectrica = pdfElectricoUrl !== null;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GDT - {nombreReal} (Vista 3D)</title>
  </head>
  <body
    class="bg-slate-950 text-slate-100 m-0 p-0 overflow-hidden select-none font-sans"
  >
    <Header />

    <div
      class="relative w-full h-[calc(100vh-64px)] bg-slate-950 overflow-hidden"
    >
      <!-- INTERFAZ FLOTANTE: CONTROLES Y VOLVER -->
      <div
        class="absolute top-0 left-0 w-full z-30 p-6 flex justify-between items-center pointer-events-none"
      >
        <div class="pointer-events-auto">
          <a
            href={`/${linea}/mapa-3d`}
            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-slate-900 border border-slate-800 text-xs text-slate-400 hover:text-white hover:border-slate-600 transition-all shadow-xl"
          >
            ← Volver al Mapa General
          </a>
          <h1
            class="text-xl font-bold text-slate-100 tracking-tight mt-3 flex items-center gap-3"
          >
            <span>{nombreReal}</span>
            <span
              class="text-xs font-mono px-2 py-0.5 rounded border border-cyan-500/30 text-cyan-400 bg-cyan-950/40"
            >
              GEMELO DIGITAL 3D
            </span>
          </h1>
        </div>

        <!-- PANEL LATERAL DE DOCUMENTACIÓN ASOCIADA -->
        <div
          class="pointer-events-auto w-80 bg-slate-900/90 border border-slate-800/80 rounded-2xl p-4 shadow-2xl backdrop-blur-md hidden md:block"
        >
          <h3
            class="text-xs font-bold uppercase text-slate-400 tracking-wider border-b border-slate-800 pb-2 mb-3"
          >
            Expediente Técnico del Nodo
          </h3>
          <div class="space-y-2 text-xs">
            <!-- Botón Lateral Eléctrico -->
            <a
              href={pdfElectrico}
              target={tieneElectrica ? "_blank" : undefined}
              class={`block p-2.5 rounded-lg bg-slate-950/60 border transition-colors group text-left decoration-none ${
                tieneElectrica
                  ? "border-slate-800 hover:border-amber-500/40 cursor-pointer"
                  : "border-slate-900/40 opacity-40 pointer-events-none select-none"
              }`}
              id="btn-consigna-elec"
            >
              <div class="flex justify-between items-center mb-1">
                <span
                  class={`font-medium ${tieneElectrica ? "text-slate-200 group-hover:text-amber-400" : "text-slate-500"}`}
                >
                  Consigna de Electrificación
                </span>
                <span
                  class="text-[10px] px-1.5 py-0.2 bg-amber-500/10 text-amber-400 rounded font-mono"
                >
                  {tieneElectrica ? "C-ELE-04" : "N/D"}
                </span>
              </div>
              <p class="text-slate-500 text-[11px]">
                {
                  tieneElectrica
                    ? "Enlace y esquemas de seccionadores de catenaria."
                    : "Documento técnico no disponible."
                }
              </p>
            </a>

            <!-- Botón Lateral Serie A -->
            <a
              href={urlConsignaA}
              target={tieneConsignaA ? "_blank" : undefined}
              class={`block p-2.5 rounded-lg bg-slate-950/60 border transition-colors group text-left decoration-none ${
                tieneConsignaA
                  ? "border-slate-800 hover:border-cyan-500/40 cursor-pointer"
                  : "border-slate-900/40 opacity-40 pointer-events-none select-none"
              }`}
              id="btn-consigna-a"
            >
              <div class="flex justify-between items-center mb-1">
                <span
                  class={`font-medium ${tieneConsignaA ? "text-slate-200 group-hover:text-cyan-400" : "text-slate-500"}`}
                >
                  Consigna A
                </span>
                <span
                  class="text-[10px] px-1.5 py-0.2 bg-cyan-500/10 text-cyan-400 rounded font-mono"
                >
                  {tieneConsignaA ? "REG-A" : "N/D"}
                </span>
              </div>
              <p class="text-slate-500 text-[11px]">
                {
                  tieneConsignaA
                    ? "Normativa de bloqueo y seguridad en andenes."
                    : "Documento técnico no disponible."
                }
              </p>
            </a>
          </div>
        </div>
      </div>

      <!-- CONTENEDOR 3D PRINCIPAL -->
      <div id="canvas-estacion" class="w-full h-full absolute inset-0 z-10">
      </div>

      <!-- CAPA SVG PARA LAS LÍNEAS TÉCNICAS (LEADER LINES) -->
      <svg
        id="svg-guias"
        class="absolute inset-0 w-full h-full pointer-events-none z-20"
      >
      </svg>

      <!-- CAPA DE TARJETAS FLOTANTES HTML -->
      <div
        id="html-labels"
        class="absolute inset-0 w-full h-full pointer-events-none z-20"
      >
        <!-- Cartel 1 Flotante 3D: Consigna de Electrificación -->
        <div
          id="tag-consigna-elec"
          class="absolute pointer-events-auto bg-slate-900/95 border border-amber-500/40 p-3 rounded-xl shadow-2xl w-56 text-xs hidden backdrop-blur-sm"
        >
          <div class="font-bold text-amber-400 mb-1 flex items-center gap-1.5">
            ⚡ Consigna Electrificación
          </div>
          <p class="text-slate-400 text-[11px] mb-2">
            {
              tieneElectrica
                ? "Punto de acometida y feeders de tracción."
                : "No se dispone de archivo de electrificación."
            }
          </p>
          {
            tieneElectrica ? (
              <a
                href={pdfElectrico}
                target="_blank"
                class="inline-block text-center w-full bg-slate-800 hover:bg-amber-600 text-white rounded p-1 transition-colors font-medium"
              >
                Abrir Documento PDF
              </a>
            ) : (
              <span class="inline-block text-center w-full bg-slate-950 text-slate-600 rounded p-1 font-medium border border-slate-900/40 cursor-not-allowed">
                No Disponible
              </span>
            )
          }
        </div>

        <!-- Cartel 2: Consigna A -->
        <div
          id="tag-consigna-a"
          class="absolute pointer-events-auto bg-slate-900/95 border border-cyan-500/40 p-3 rounded-xl shadow-2xl w-56 text-xs hidden backdrop-blur-sm"
        >
          <div class="font-bold text-cyan-400 mb-1 flex items-center gap-1.5">
            🏢 Consigna A (Estación)
          </div>
          <p class="text-slate-400 text-[11px] mb-2">
            {
              tieneConsignaA
                ? "Gálibos de andén y cableado de señales."
                : "No se han encontrado planos para este nodo."
            }
          </p>
          {
            tieneConsignaA ? (
              <a
                href={urlConsignaA}
                target="_blank"
                class="inline-block text-center w-full bg-slate-800 hover:bg-cyan-600 text-white rounded p-1 transition-colors font-medium"
              >
                Ver Planos Adjuntos
              </a>
            ) : (
              <span class="inline-block text-center w-full bg-slate-950 text-slate-600 rounded p-1 font-medium border border-slate-900/40 cursor-not-allowed">
                No Disponible
              </span>
            )
          }
        </div>
      </div>
    </div>
  </body>
</html>

<script>
  import * as THREE from "three";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";

  const container = document.getElementById("canvas-estacion");

  if (container) {
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x020617);

    const persCamera = new THREE.PerspectiveCamera(
      45,
      container.clientWidth / container.clientHeight,
      0.1,
      1000,
    );
    persCamera.position.set(60, 40, 80);

    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.shadowMap.enabled = true;
    container.appendChild(renderer.domElement);

    const controls = new OrbitControls(persCamera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.maxPolarAngle = Math.PI / 2 - 0.05;

    const ambientLight = new THREE.AmbientLight(0xffffff, 0.4);
    scene.add(ambientLight);

    const dirLight = new THREE.DirectionalLight(0xffffff, 0.8);
    dirLight.position.set(40, 60, 20);
    dirLight.castShadow = true;
    scene.add(dirLight);

    const entornoGroup = new THREE.Group();
    scene.add(entornoGroup);

    const textureLoader = new THREE.TextureLoader();

    const texturaCesped = textureLoader.load(
      "https://threejs.org/examples/textures/terrain/grasslight-big.jpg",
      (texture) => {
        texture.wrapS = THREE.RepeatWrapping;
        texture.wrapT = THREE.RepeatWrapping;
        texture.repeat.set(25, 25);
      },
    );

    const matCespedReal = new THREE.MeshStandardMaterial({
      map: texturaCesped,
      roughness: 0.9,
      metalness: 0.1,
    });

    const cespedGeo = new THREE.PlaneGeometry(400, 400);
    const cespedMesh = new THREE.Mesh(cespedGeo, matCespedReal);
    cespedMesh.rotation.x = -Math.PI / 2;
    cespedMesh.position.y = -0.02;
    cespedMesh.receiveShadow = true;
    entornoGroup.add(cespedMesh);

    const matAsfalto = new THREE.MeshStandardMaterial({
      color: 0x1e293b,
      roughness: 0.8,
    });
    const parkingGeo = new THREE.PlaneGeometry(160, 50);
    const parkingMesh = new THREE.Mesh(parkingGeo, matAsfalto);
    parkingMesh.rotation.x = -Math.PI / 2;
    parkingMesh.position.set(0, -0.01, 35);
    parkingMesh.receiveShadow = true;
    entornoGroup.add(parkingMesh);

    const matAndenHormigon = new THREE.MeshStandardMaterial({
      color: 0x475569,
      roughness: 0.7,
    });
    const andenGeo = new THREE.BoxGeometry(180, 0.2, 10);
    const andenMesh = new THREE.Mesh(andenGeo, matAndenHormigon);
    andenMesh.position.set(0, 0.1, -11);
    andenMesh.receiveShadow = true;
    entornoGroup.add(andenMesh);

    const edificioGroup = new THREE.Group();
    scene.add(edificioGroup);

    let puntoAnclajeTejado = new THREE.Vector3(0, 15, 0);
    let puntoAlcanjeLateral = new THREE.Vector3(12, 4, 7);
    let modeloCargado = false;

    const path = window.location.pathname.toLowerCase();
    let slugActual = path.split("/").pop().replace("-3d", "");

    slugActual = decodeURIComponent(slugActual)
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");

    async function inicializarArquitecturaEstacion() {
      try {
        const moduloEstacion = await import(
          `../../components/estaciones/${slugActual}.js`
        );
        moduloEstacion.cargarModelo(
          edificioGroup,
          puntoAnclajeTejado,
          puntoAlcanjeLateral,
        );
        console.log(
          `[GDT] Arquitectura personalizada cargada con éxito: ${slugActual}`,
        );
      } catch (error) {
        console.warn(
          `[GDT] No existe modelo para "${slugActual}". Cargando entorno regional genérico.`,
        );
        const moduloGenerico = await import(
          `../../components/estaciones/generica.js`
        );
        moduloGenerico.cargarModelo(
          edificioGroup,
          puntoAnclajeTejado,
          puntoAlcanjeLateral,
        );
      } finally {
        modeloCargado = true;
      }
    }

    inicializarArquitecturaEstacion();

    const svgOverlay = document.getElementById("svg-guias");
    const tagElec = document.getElementById("tag-consigna-elec");
    const tagConsignaA = document.getElementById("tag-consigna-a");
    function proyectarLineasYEtiquetas() {
      if (!svgOverlay || !tagElec || !tagConsignaA || !modeloCargado) return;

      let htmlContenidoSVG = "";

      const configuraciones = [
        {
          punto3D: puntoAnclajeTejado,
          tagHTML: tagElec,
          offsetX: 160,
          offsetY: -120,
          color: "#f59e0b",
        },
        {
          punto3D: puntoAlcanjeLateral,
          tagHTML: tagConsignaA,
          offsetX: -240,
          offsetY: -140,
          color: "#06b6d4",
        },
      ];

      // CORREGIDO: Usamos el mismo nombre de la variable de arriba
      configuraciones.forEach((cfg) => {
        const wp = cfg.punto3D.clone();
        wp.project(persCamera);

        if (wp.z > 1) {
          cfg.tagHTML.style.display = "none";
          return;
        }

        const x = (wp.x * 0.5 + 0.5) * container.clientWidth;
        const y = (-(wp.y * 0.5) + 0.5) * container.clientHeight;

        cfg.tagHTML.style.display = "block";
        cfg.tagHTML.style.left = `${x + cfg.offsetX}px`;
        cfg.tagHTML.style.top = `${y + cfg.offsetY}px`;

        const xCartelAnclaje = x + cfg.offsetX + (cfg.offsetX > 0 ? 0 : 224);
        const yCartelAnclaje = y + cfg.offsetY + 20;

        htmlContenidoSVG += `
          <polyline 
            points="${x},${y} ${xCartelAnclaje - (cfg.offsetX > 0 ? 30 : -30)},${yCartelAnclaje} ${xCartelAnclaje},${yCartelAnclaje}" 
            style="fill:none; stroke:${cfg.color}; stroke-width:1.5; stroke-dasharray: 4 3;"
          />
          <circle cx="${x}" cy="${y}" r="3.5" style="fill:${cfg.color}; stroke:#020617; stroke-width:1;" />
        `;
      });

      svgOverlay.innerHTML = htmlContenidoSVG;
    }

    function animate() {
      requestAnimationFrame(animate);
      controls.update();
      proyectarLineasYEtiquetas();
      renderer.render(scene, persCamera);
    }

    animate();

    window.addEventListener("resize", () => {
      persCamera.aspect = container.clientWidth / container.clientHeight;
      persCamera.updateProjectionMatrix();
      renderer.setSize(container.clientWidth, container.clientHeight);
    });
  }
</script>
