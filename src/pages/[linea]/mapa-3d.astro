---
// src/pages/[linea]/mapa-3d.astro
import fs from "node:fs";
import path from "node:path";
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

// Importación segmentada limpia de los datos de infraestructura externa
import { CONFIG_MAPAS, TRAMOS_VIAS } from "../../data/geo-infraestructura.js";
export function getStaticPaths() {
  return [
    { params: { linea: "pe-17" } },
    { params: { linea: "pe-24" } },
    { params: { linea: "pe-26" } },
  ];
}

const { linea } = Astro.params;
const codigoLineaUpper = linea.toUpperCase();

const coordMapa = CONFIG_MAPAS[codigoLineaUpper] || {};
const tramosDeEstaLinea = TRAMOS_VIAS[linea] || [];
const estacionesUnicas = [...new Set(tramosDeEstaLinea.flat())];

// Detección automática de subestaciones por lectura de archivos de consigna
const limpiarParaMatch = (str: string) => {
  return str
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]/g, "");
};

const docsDir = path.join(process.cwd(), "public", "docs", "Consignas finales");
const subestacionesDetectadas = new Set<string>();

if (fs.existsSync(docsDir)) {
  const allFiles = fs.readdirSync(docsDir, { recursive: true }) as string[];
  allFiles.forEach((file) => {
    const normPath = file.replace(/\\/g, "/");
    if (normPath.toLowerCase().startsWith(linea.toLowerCase() + "/")) {
      const fileName = normPath.split("/").pop() || "";
      if (
        fileName.toLowerCase().includes("s.e.") ||
        fileName.toLowerCase().includes("subestacion")
      ) {
        subestacionesDetectadas.add(limpiarParaMatch(fileName));
      }
    }
  });
}

// Mapeado completo de nodos reales para pasárselo a Three.js
const nodosEstructurados = estacionesUnicas.map((nombre) => {
  const coords = coordMapa[nombre] || { x: 50, y: 50 };
  const tokenEstacion = limpiarParaMatch(nombre);
  let tieneSub = false;

  subestacionesDetectadas.forEach((subToken) => {
    if (subToken.includes(tokenEstacion) || tokenEstacion.includes(subToken))
      tieneSub = true;
  });

  if (
    [
      "Dos Hermanas",
      "Lebrija",
      "Cortadura",
      "Lora del Río",
      "Sevilla Santa Justa",
    ].includes(nombre)
  ) {
    tieneSub = true;
  }

  // Generación exacta del slug compatible con las rutas del dashboard original
  const slugEstacion = nombre
    .toLowerCase()
    .replace(/\./g, "")
    .replace(/[\s\-]+/g, "-")
    .replace(/[^a-z0-9\-áéíóúñ]/g, "");

  return {
    nombre,
    slug: slugEstacion,
    x: coords.x * 15,
    y: coords.y * 7,
    tieneSub,
  };
});

const tramosPara3D = tramosDeEstaLinea.map((tramo) => {
  return tramo.map((nombreEst, idx) => {
    if (
      linea === "pe-26" &&
      tramo.includes("Apd. S. Jerónimo-Apd. Estadio-Apd. Cartuja") &&
      idx === 0
    ) {
      const m = coordMapa["Majarabique"] || { x: 92, y: 25 };
      const a = coordMapa["Alamillo"] || { x: 84, y: 27 };
      return { x: ((m.x + a.x) / 2) * 15, y: ((m.y + a.y) / 2) * 7 };
    }
    const coords = coordMapa[nombreEst] || { x: 50, y: 50 };
    return { x: coords.x * 15, y: coords.y * 7 };
  });
});
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Maqueta Volumétrica 3D - {codigoLineaUpper}</title>
  </head>
  <body class="bg-slate-950 min-h-screen flex flex-col antialiased text-white">
    <Header lineaActiva={linea} />

    <main
      class="max-w-[1600px] mx-auto p-4 md:p-8 w-full flex-1 flex flex-col min-h-0"
    >
      <div
        class="flex items-center gap-4 mb-6 border-b border-slate-800 pb-4 shrink-0"
      >
        <span
          class="text-xs font-mono uppercase bg-cyan-950 text-cyan-300 border border-cyan-800/80 px-3 py-1 rounded font-bold"
        >
          {codigoLineaUpper} - LABORATORIO INTERACTIVO
        </span>
        <h1 class="text-xl font-bold tracking-tight">
          Esquema Volumétrico de la Red
        </h1>
      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-12 gap-6 flex-1 items-stretch min-h-0"
      >
        <!-- PANEL IZQUIERDO: SECCIÓN DE DATOS DE RED -->
        <div class="lg:col-span-4 flex flex-col gap-4">
          <div
            class="bg-slate-900 border border-slate-800 rounded-2xl p-5 shadow-xl"
          >
            <h2
              class="text-xs font-bold uppercase text-amber-500 tracking-widest mb-1"
            >
              Control de Navegación
            </h2>
            <p class="text-xs text-slate-400 leading-relaxed">
              Pasa el ratón por encima de cualquier estructura en el lienzo 3D
              para iluminarla. **Haz clic izquierdo directo** sobre la estación
              u obra civil para abrir instantáneamente sus planos técnicos de
              electrificación.
            </p>
          </div>

          <div
            class="bg-slate-900 border border-slate-800 rounded-2xl p-5 shadow-xl flex-1 overflow-y-auto max-h-[400px] lg:max-h-none"
          >
            <h3
              class="text-xs font-bold uppercase text-slate-400 tracking-widest border-b border-slate-800 pb-2 mb-3"
            >
              Nodos Identificados ({nodosEstructurados.length})
            </h3>
            <ul class="space-y-1 text-xs text-slate-400">
              {
                nodosEstructurados.map((n) => (
                  <li class="p-2 bg-slate-950/40 border border-slate-900 rounded-lg flex justify-between items-center group hover:border-slate-700 transition-colors">
                    <a
                      href={`/${linea}/${n.slug}`}
                      class="font-medium text-slate-200 group-hover:text-cyan-400 transition-colors"
                    >
                      {n.nombre}
                    </a>
                    <span
                      class={`text-[10px] font-mono px-2 py-0.5 rounded border ${n.tieneSub ? "text-amber-400 bg-amber-950/50 border-amber-900" : "text-cyan-400 bg-cyan-950/50 border-cyan-900"}`}
                    >
                      {n.tieneSub ? "S/E" : "ESTACIÓN"}
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <!-- PANEL DERECHO: INTERFAZ WEBGL CANVAS -->
        <div
          class="lg:col-span-8 bg-slate-900 border border-slate-800 rounded-2xl relative min-h-[500px] lg:min-h-0 overflow-hidden flex flex-col shadow-2xl"
        >
          <!-- Tooltip flotante reactivo -->
          <div
            id="3d-tooltip"
            class="absolute pointer-events-none bg-slate-950/95 border border-slate-800 text-white font-sans text-xs font-semibold px-3 py-2 rounded-xl hidden z-20 shadow-xl transition-opacity duration-150"
          >
          </div>

          <div
            class="absolute top-4 left-4 z-10 bg-slate-950/90 border border-slate-800 px-3 py-1.5 rounded-lg text-[11px] text-slate-300 font-mono flex gap-4"
          >
            <div>
              Render: <span class="text-emerald-400"
                >Three.js Raycaster Map</span
              >
            </div>
            <div class="text-slate-500">|</div>
            <div class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> Subestaciones
            </div>
            <div class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span> Estaciones
            </div>
          </div>

          <div
            id="container-3d"
            data-nodos={JSON.stringify(nodosEstructurados)}
            data-tramos={JSON.stringify(tramosPara3D)}
            data-lineacod={linea}
            class="w-full h-full flex-1"
          >
          </div>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<script>
  import * as THREE from "three";
  import { OrbitControls } from "three/addons/controls/OrbitControls.js";

  function initThreeJS() {
    const container = document.getElementById("container-3d");
    const tooltip = document.getElementById("3d-tooltip");
    if (!container || !tooltip) return;

    const nodos = JSON.parse(container.getAttribute("data-nodos") || "[]");
    const tramos = JSON.parse(container.getAttribute("data-tramos") || "[]");
    const lineaCod = container.getAttribute("data-lineacod");

    if (nodos.length === 0) return;

    const width = container.clientWidth || 800;
    const height = container.clientHeight || 500;

    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x020617);

    const camera = new THREE.PerspectiveCamera(45, width / height, 1, 2000);
    camera.position.set(0, 180, 260);

    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(width, height);

    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;

    container.appendChild(renderer.domElement);

    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;

    const ambientLight = new THREE.AmbientLight(0x475569, 2.2);
    scene.add(ambientLight);

    const directionalLight = new THREE.DirectionalLight(0xffffff, 1.5);
    directionalLight.position.set(100, 250, 100);

    directionalLight.castShadow = true;
    directionalLight.shadow.mapSize.width = 2048;
    directionalLight.shadow.mapSize.height = 2048;
    const d = 400;
    directionalLight.shadow.camera.left = -d;
    directionalLight.shadow.camera.right = d;
    directionalLight.shadow.camera.top = d;
    directionalLight.shadow.camera.bottom = -d;
    directionalLight.shadow.camera.far = 1500;

    scene.add(directionalLight);

    const xValues = nodos.map((n: any) => n.x);
    const yValues = nodos.map((n: any) => n.y);
    const minX = Math.min(...xValues);
    const maxX = Math.max(...xValues);
    const minY = Math.min(...yValues);
    const maxY = Math.max(...yValues);

    const centroX = (minX + maxX) / 2;
    const centroZ = (minY + maxY) / 2;
    const rangoMax = Math.max(maxX - minX, maxY - minY) || 1;
    const escala = 650 / rangoMax;
    const objetosInteractivos: THREE.Object3D[] = [];
    const mapaDatosObjeto = new Map();

    // Array global necesario para alimentar y amoldar el terreno en base a las coordenadas de la vía
    const todosLosPuntosDeVias: THREE.Vector3[] = [];

    // 1. GENERADOR DE VÍAS FERROVIARIAS (Y OBTENCIÓN DE DIODOS METRICOS)
    tramos.forEach((tram) => {
      const puntosTramo3D = tram.map((punpoint: any) => {
        const posX = (punpoint.x - centroX) * escala;
        const posZ = (punpoint.y - centroZ) * escala;
        return new THREE.Vector3(posX, 0, posZ);
      });

      if (puntosTramo3D.length > 1) {
        const curvaVia = new THREE.CatmullRomCurve3(puntosTramo3D);
        curvaVia.curveType = "centripetal";

        const anchoVia = 5.0;
        const radioRail = 0.45;
        const pasoTraviesas = 4.0;

        const divisiones = tram.length * 20;
        const puntosCentro: THREE.Vector3[] = [];
        const perpendiculares: THREE.Vector3[] = [];

        for (let i = 0; i <= divisiones; i++) {
          const t = i / divisiones;
          const posCentro = curvaVia.getPointAt(t);
          const tangente = curvaVia.getTangentAt(t).normalize();
          const perpendicular = new THREE.Vector3(
            -tangente.z,
            0,
            tangente.x,
          ).normalize();

          puntosCentro.push(posCentro);
          perpendiculares.push(perpendicular);
        }

        // A. BALASTO
        const geometryBalasto = new THREE.BufferGeometry();
        const verticesBalasto: number[] = [];
        const anchoBalasto = anchoVia * 1.5;

        for (let i = 0; i <= divisiones; i++) {
          const pos = puntosCentro[i];
          const perp = perpendiculares[i];
          const pIzq = pos.clone().addScaledVector(perp, anchoBalasto / 2);
          const pDer = pos.clone().addScaledVector(perp, -anchoBalasto / 2);

          verticesBalasto.push(pIzq.x, 0.02, pIzq.z);
          verticesBalasto.push(pDer.x, 0.02, pDer.z);
        }

        const indicesBalasto: number[] = [];
        for (let i = 0; i < divisiones; i++) {
          const vid = i * 2;
          indicesBalasto.push(vid, vid + 1, vid + 2);
          indicesBalasto.push(vid + 1, vid + 3, vid + 2);
        }

        geometryBalasto.setAttribute(
          "position",
          new THREE.Float32BufferAttribute(verticesBalasto, 3),
        );
        geometryBalasto.setIndex(indicesBalasto);
        geometryBalasto.computeVertexNormals();

        const materialBalasto = new THREE.MeshStandardMaterial({
          color: 0x1e293b,
          roughness: 0.9,
          metalness: 0.1,
          side: THREE.DoubleSide,
        });
        const balasto = new THREE.Mesh(geometryBalasto, materialBalasto);
        scene.add(balasto);

        // B. TRAVIESAS INDEPENDIENTES
        const longitudCurva = curvaVia.getLength();
        const numeroTraviesas = Math.floor(longitudCurva / pasoTraviesas);
        const geomTraviesa = new THREE.BoxGeometry(anchoVia * 1.4, 0.3, 0.8);
        const materialMadera = new THREE.MeshStandardMaterial({
          color: 0x78350f,
          roughness: 0.8,
          metalness: 0.1,
        });

        for (let j = 0; j <= numeroTraviesas; j++) {
          const t = j / numeroTraviesas;
          const posCentro = curvaVia.getPointAt(t);
          const tangente = curvaVia.getTangentAt(t).normalize();

          const traviesa = new THREE.Mesh(geomTraviesa, materialMadera);
          traviesa.position.copy(posCentro).setY(0.2);

          const anguloY = Math.atan2(tangente.x, tangente.z);
          traviesa.rotation.y = anguloY;

          scene.add(traviesa);
        }

        // C. DOBLE CARRIL DE ACERO
        const puntosCarrilIzq: THREE.Vector3[] = [];
        const puntosCarrilDer: THREE.Vector3[] = [];

        for (let i = 0; i <= divisiones; i++) {
          const pos = puntosCentro[i];
          const perp = perpendiculares[i];

          puntosCarrilIzq.push(
            pos
              .clone()
              .addScaledVector(perp, anchoVia / 2)
              .setY(0.4),
          );
          puntosCarrilDer.push(
            pos
              .clone()
              .addScaledVector(perp, -anchoVia / 2)
              .setY(0.4),
          );
        }

        const materialAcero = new THREE.MeshStandardMaterial({
          color: 0x94a3b8,
          metalness: 0.9,
          roughness: 0.2,
        });

        const curvaIzq = new THREE.CatmullRomCurve3(puntosCarrilIzq);
        const geomCarrilIzq = new THREE.TubeGeometry(
          curvaIzq,
          divisiones,
          radioRail,
          6,
          false,
        );
        const carrilIzq = new THREE.Mesh(geomCarrilIzq, materialAcero);
        scene.add(carrilIzq);

        const curvaDer = new THREE.CatmullRomCurve3(puntosCarrilDer);
        const geomCarrilDer = new THREE.TubeGeometry(
          curvaDer,
          divisiones,
          radioRail,
          6,
          false,
        );
        const carrilDer = new THREE.Mesh(geomCarrilDer, materialAcero);
        scene.add(carrilDer);

        todosLosPuntosDeVias.push(...puntosCentro);
      }
    });
    // 2. MODULACIÓN E INSTANCIACIÓN DE GRANDES EDIFICIOS DE VIAJEROS (ESTILO ADIF REALISTA)
    nodos.forEach((nodo: any) => {
      const posX = (nodo.x - centroX) * escala;
      const posZ = (nodo.y - centroZ) * escala;

      // === CÁLCULO DE ALTURA EXACTA DEL TERRENO EN LA POSICIÓN DEL NODO ===
      let distanciaMinimaAVia = Infinity;
      if (todosLosPuntosDeVias.length > 0) {
        for (let j = 0; j < todosLosPuntosDeVias.length; j += 4) {
          const puntoVia = todosLosPuntosDeVias[j];
          const dx = posX - puntoVia.x;
          const dz = posZ - puntoVia.z;
          const distSq = dx * dx + dz * dz;
          if (distSq < distanciaMinimaAVia) distanciaMinimaAVia = distSq;
        }
        distanciaMinimaAVia = Math.sqrt(distanciaMinimaAVia);
      } else {
        distanciaMinimaAVia = 999;
      }

      const factorElevacion = THREE.MathUtils.smoothstep(
        distanciaMinimaAVia,
        20,
        90,
      );
      let alturaTerrenoY = Math.sin(posX * 0.01) * Math.cos(posZ * 0.01) * 35;
      alturaTerrenoY += Math.sin(posX * 0.03) * Math.sin(posZ * 0.02) * 12;
      alturaTerrenoY += Math.cos(posX * 0.08) * Math.sin(posZ * 0.08) * 3;
      alturaTerrenoY *= factorElevacion;
      // ===================================================================

      const colorFuncional = nodo.tieneSub ? 0xf59e0b : 0x06b6d4;

      // Grupo contenedor del complejo de la estación
      const estacionVisual = new THREE.Group();

      // MATERIALES COMUNES PARA EL COMPLEJO
      const matMuros = new THREE.MeshStandardMaterial({
        color: 0xeae6e1, // Blanco hueso / Arena claro realista de estación
        roughness: 0.7,
        metalness: 0.1,
      });
      const matZocalo = new THREE.MeshStandardMaterial({
        color: 0x475569, // Gris pizarra para la base protectora e industrial
        roughness: 0.8,
      });
      const matTejadoOriginal = new THREE.MeshStandardMaterial({
        color: 0x9a3412, // Color arcilla/teja tradicional español
        roughness: 0.7,
        flatShading: true,
      });

      // A. EL ANDÉN INMIGRADO AL ENTORNO (Ahora mucho más largo, 45 unidades)
      const andenGeo = new THREE.BoxGeometry(45, 1.2, 12);
      const anden = new THREE.Mesh(andenGeo, matZocalo);
      anden.position.set(0, 0.6, 0); // Apoyado en el suelo
      anden.castShadow = true;
      anden.receiveShadow = true;
      estacionVisual.add(anden);

      // B. EDIFICIO CENTRAL (Cuerpo principal de 2 plantas)
      // Escala mayor para que se imponga como el centro logístico real
      const cuerpoCentralGeo = new THREE.BoxGeometry(14, 11, 8);
      const cuerpoCentral = new THREE.Mesh(cuerpoCentralGeo, matMuros);
      cuerpoCentral.position.set(0, 5.5 + 1.2, -1.5); // Desplazado sutilmente hacia atrás del andén
      cuerpoCentral.castShadow = true;
      cuerpoCentral.receiveShadow = true;
      estacionVisual.add(cuerpoCentral);

      // Tejado del edificio central (Clásico a dos aguas sutil)
      const tejadoCentralGeo = new THREE.ConeGeometry(9, 3, 4);
      const tejadoCentral = new THREE.Mesh(tejadoCentralGeo, matTejadoOriginal);
      tejadoCentral.position.set(0, 11 + 1.2 + 1.5, -1.5);
      tejadoCentral.rotation.y = Math.PI / 4; // Alineación poligonal
      tejadoCentral.scale.set(1.6, 1, 1.1);
      tejadoCentral.castShadow = true;
      estacionVisual.add(tejadoCentral);

      // C. ALAS LATERALES ALARGADAS (Cuerpos de 1 planta a izquierda y derecha)
      const alaGeo = new THREE.BoxGeometry(14, 6.5, 7);

      const alaIzquierda = new THREE.Mesh(alaGeo, matMuros);
      alaIzquierda.position.set(-14, 3.25 + 1.2, -1.5);
      alaIzquierda.castShadow = true;
      alaIzquierda.receiveShadow = true;
      estacionVisual.add(alaIzquierda);

      const alaDerecha = new THREE.Mesh(alaGeo, matMuros);
      alaDerecha.position.set(14, 3.25 + 1.2, -1.5);
      alaDerecha.castShadow = true;
      alaDerecha.receiveShadow = true;
      estacionVisual.add(alaDerecha);

      // Tejados inclinados para las alas laterales
      const tejadoAlaGeo = new THREE.BoxGeometry(15, 0.5, 7.5);

      const tejadoAlaIzquierda = new THREE.Mesh(
        tejadoAlaGeo,
        matTejadoOriginal,
      );
      tejadoAlaIzquierda.position.set(-14, 6.5 + 1.2 + 0.25, -1.5);
      tejadoAlaIzquierda.rotation.z = -0.05; // Caída de agua realista
      tejadoAlaIzquierda.castShadow = true;
      estacionVisual.add(tejadoAlaIzquierda);

      const tejadoAlaDerecha = new THREE.Mesh(tejadoAlaGeo, matTejadoOriginal);
      tejadoAlaDerecha.position.set(14, 6.5 + 1.2 + 0.25, -1.5);
      tejadoAlaDerecha.rotation.z = 0.05;
      tejadoAlaDerecha.castShadow = true;
      estacionVisual.add(tejadoAlaDerecha);

      // D. GRAN MARQUESINA FRONTAL DE PASAJEROS
      // Integra el color de monitorización del dashboard (azul o naranja) en el canto
      const marquesinaGeo = new THREE.BoxGeometry(38, 0.4, 4.5);
      const matMarquesina = new THREE.MeshStandardMaterial({
        color: colorFuncional, // Identificador de estado intacto
        roughness: 0.3,
        metalness: 0.5,
      });
      const marquesina = new THREE.Mesh(marquesinaGeo, matMarquesina);
      marquesina.position.set(0, 5.5, 2.5); // Volada cubriendo la zona de espera junto a la vía
      marquesina.castShadow = true;
      estacionVisual.add(marquesina);

      // Columnas finas de soporte metálico para la marquesina frontal
      const soporteGeo = new THREE.CylinderGeometry(0.12, 0.12, 5.5, 4);
      const matSoporte = new THREE.MeshStandardMaterial({
        color: 0x1e293b,
        metalness: 0.8,
      });

      const offsetsX = [-16, -7, 7, 16];
      offsetsX.forEach((ox) => {
        const pilar = new THREE.Mesh(soporteGeo, matSoporte);
        pilar.position.set(ox, 2.75 + 1.2, 4.2);
        pilar.castShadow = true;
        estacionVisual.add(pilar);
      });

      // Asentamos todo el complejo sobre las coordenadas escaladas y el relieve real
      estacionVisual.position.set(posX, alturaTerrenoY, posZ);

      // Orientación automática: Orientamos el frontal del edificio mirando al eje de vías de forma armónica
      estacionVisual.rotation.y = Math.atan2(posX, posZ) * 0.1;

      scene.add(estacionVisual);

      // Mapeamos los datos para el Raycaster original usando la marquesina de color como objetivo de hover
      mapaDatosObjeto.set(estacionVisual.id, {
        nombre: nodo.nombre,
        slug: nodo.slug,
        tipo: nodo.tieneSub ? "Subestación S/E" : "Estación Ferroviaria",
        colorOriginal: colorFuncional,
        esGrupoComplejo: true,
        componenteColor: marquesina, // Mapeado al techo de la plataforma para los brillos reactivos
      });

      objetosInteractivos.push(estacionVisual);
    });

    // 3. GEOMETRÍA DE ALTA RESOLUCIÓN DEL TERRENO NATURAL
    const tamañoTerreno = 1000;
    const segmentos = 256;
    const terrainGeo = new THREE.PlaneGeometry(
      tamañoTerreno,
      tamañoTerreno,
      segmentos,
      segmentos,
    );

    const posAttr = terrainGeo.attributes.position;
    const verticesCount = posAttr.count;

    for (let i = 0; i < verticesCount; i++) {
      const localX = posAttr.getX(i);
      const localY = posAttr.getY(i);

      const mundoX = localX;
      const mundoZ = -localY;

      let distanciaMinimaAVia = Infinity;

      if (todosLosPuntosDeVias.length > 0) {
        for (let j = 0; j < todosLosPuntosDeVias.length; j += 4) {
          const puntoVia = todosLosPuntosDeVias[j];
          const dx = mundoX - puntoVia.x;
          const dz = mundoZ - puntoVia.z;
          const distSq = dx * dx + dz * dz;

          if (distSq < distanciaMinimaAVia) {
            distanciaMinimaAVia = distSq;
          }
        }
        distanciaMinimaAVia = Math.sqrt(distanciaMinimaAVia);
      } else {
        distanciaMinimaAVia = 999;
      }

      const factorElevacion = THREE.MathUtils.smoothstep(
        distanciaMinimaAVia,
        20,
        90,
      );

      let z = Math.sin(mundoX * 0.01) * Math.cos(mundoZ * 0.01) * 35;
      z += Math.sin(mundoX * 0.03) * Math.sin(mundoZ * 0.02) * 12;
      z += Math.cos(mundoX * 0.08) * Math.sin(mundoZ * 0.08) * 3;

      posAttr.setZ(i, z * factorElevacion);
    }

    terrainGeo.computeVertexNormals();
    posAttr.needsUpdate = true;

    // 4. TEXTURA FOTORREALISTA DE TERRENO NATURAL DEFINIDO
    const textureLoader = new THREE.TextureLoader();
    const texturaTerreno = textureLoader.load(
      "https://threejs.org/examples/textures/terrain/grasslight-big.jpg",
    );

    texturaTerreno.wrapS = THREE.RepeatWrapping;
    texturaTerreno.wrapT = THREE.RepeatWrapping;
    texturaTerreno.repeat.set(8, 8);
    texturaTerreno.anisotropy = renderer.capabilities.getMaxAnisotropy();

    const terrainMat = new THREE.MeshStandardMaterial({
      map: texturaTerreno,
      roughness: 0.9,
      metalness: 0.05,
      flatShading: false,
    });

    const terrain = new THREE.Mesh(terrainGeo, terrainMat);
    terrain.rotation.x = -Math.PI / 2;
    terrain.receiveShadow = true;
    scene.add(terrain);

    // 5. GENERACIÓN DE ÁRBOLES FOTORREALISTAS ASIMÉTRICOS
    const numArboles = 150;
    const copaGeo = new THREE.DodecahedronGeometry(5, 1);

    const posicionVertices = copaGeo.attributes.position;
    for (let i = 0; i < posicionVertices.count; i++) {
      let vx = posicionVertices.getX(i);
      let vy = posicionVertices.getY(i);
      let vz = posicionVertices.getZ(i);

      vx += (Math.random() - 0.5) * 1.6;
      vy += (Math.random() - 0.5) * 1.6;
      vz += (Math.random() - 0.5) * 1.6;

      posicionVertices.setXYZ(i, vx, vy, vz);
    }

    posicionVertices.needsUpdate = true;
    copaGeo.computeVertexNormals();

    const textureLoaderArbol = new THREE.TextureLoader();
    const texturaHojas = textureLoaderArbol.load(
      "https://threejs.org/examples/textures/terrain/grasslight-big.jpg",
    );
    texturaHojas.wrapS = THREE.RepeatWrapping;
    texturaHojas.wrapT = THREE.RepeatWrapping;
    texturaHojas.repeat.set(4, 4);

    const arbolMat = new THREE.MeshStandardMaterial({
      map: texturaHojas,
      color: 0x14321a,
      roughness: 0.95,
      metalness: 0.0,
      flatShading: true,
    });

    const meshArboles = new THREE.InstancedMesh(copaGeo, arbolMat, numArboles);
    meshArboles.castShadow = true;
    meshArboles.receiveShadow = true;

    const dummy = new THREE.Object3D();
    let arbolesColocados = 0;
    let intentos = 0;

    while (arbolesColocados < numArboles && intentos < 1000) {
      intentos++;
      const randX = (Math.random() - 0.5) * tamañoTerreno;
      const randZ = (Math.random() - 0.5) * tamañoTerreno;

      let cercaDeVia = false;
      if (todosLosPuntosDeVias.length > 0) {
        // Analizamos los puntos de la vía para asegurar que ningún árbol invada el trazado
        for (let j = 0; j < todosLosPuntosDeVias.length; j += 6) {
          // Paso un poco más largo para mantener rendimiento
          const puntoVia = todosLosPuntosDeVias[j];
          const dx = randX - puntoVia.x;
          const dz = randZ - puntoVia.z;

          // Subimos el umbral de 500 a 3000 para ensanchar el pasillo libre de vegetación
          if (dx * dx + dz * dz < 3000) {
            cercaDeVia = true;
            break;
          }
        }
      }

      if (!cercaDeVia) {
        let distanciaMinimaAVia = Infinity;
        // ... (El resto del cálculo de la alturaY y el factorElevacion se queda exactamente igual)
        if (todosLosPuntosDeVias.length > 0) {
          for (let j = 0; j < todosLosPuntosDeVias.length; j += 4) {
            const puntoVia = todosLosPuntosDeVias[j];
            const dx = randX - puntoVia.x;
            const dz = randZ - puntoVia.z;
            const distSq = dx * dx + dz * dz;
            if (distSq < distanciaMinimaAVia) {
              distanciaMinimaAVia = distSq;
            }
          }
          distanciaMinimaAVia = Math.sqrt(distanciaMinimaAVia);
        } else {
          distanciaMinimaAVia = 999;
        }

        const factorElevacion = THREE.MathUtils.smoothstep(
          distanciaMinimaAVia,
          20,
          90,
        );

        let alturaY = Math.sin(randX * 0.01) * Math.cos(randZ * 0.01) * 35;
        alturaY += Math.sin(randX * 0.03) * Math.sin(randZ * 0.02) * 12;
        alturaY += Math.cos(randX * 0.08) * Math.sin(randZ * 0.08) * 3;
        alturaY *= factorElevacion;

        dummy.position.set(randX, alturaY + 3, randZ);

        const escalaAleatoria = 0.6 + Math.random() * 0.8;
        dummy.scale.set(
          escalaAleatoria,
          escalaAleatoria * 1.2,
          escalaAleatoria,
        );

        dummy.rotation.set(
          Math.random() * Math.PI,
          Math.random() * Math.PI,
          Math.random() * Math.PI,
        );

        dummy.updateMatrix();
        meshArboles.setMatrixAt(arbolesColocados, dummy.matrix);
        arbolesColocados++;
      }
    }

    scene.add(meshArboles);

    // INTERACTIVIDAD AVANZADA (RAYCASTER POR JERARQUÍAS GRUPALES)
    const raycaster = new THREE.Raycaster();
    const mouse = new THREE.Vector2();
    let objetoInterseccionadoAnterior: any = null;

    function onMouseMove(event: MouseEvent) {
      const rect = renderer.domElement.getBoundingClientRect();
      mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
      mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;

      tooltip!.style.left = `${event.clientX - rect.left + 15}px`;
      tooltip!.style.top = `${event.clientY - rect.top + 15}px`;
    }

    function onDocumentClick(event: MouseEvent) {
      const rect = renderer.domElement.getBoundingClientRect();
      mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
      mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;

      raycaster.setFromCamera(mouse, camera);
      const intersections = raycaster.intersectObjects(
        objetosInteractivos,
        true,
      );

      if (intersections.length > 0) {
        let rootGroup = intersections[0].object;
        while (rootGroup.parent && rootGroup.parent !== scene) {
          rootGroup = rootGroup.parent;
        }

        const datos = mapaDatosObjeto.get(rootGroup.id);
        if (datos && datos.slug) {
          window.location.href = `/${lineaCod}/${datos.slug}`;
        }
      }
    }

    container.addEventListener("mousemove", onMouseMove);
    container.addEventListener("click", onDocumentClick);

    function animate() {
      requestAnimationFrame(animate);
      controls.update();

      raycaster.setFromCamera(mouse, camera);
      const intersections = raycaster.intersectObjects(
        objetosInteractivos,
        true,
      );

      if (intersections.length > 0) {
        let objetoActual = intersections[0].object;
        while (objetoActual.parent && objetoActual.parent !== scene) {
          objetoActual = objetoActual.parent;
        }

        if (objetoInterseccionadoAnterior !== objetoActual) {
          if (objetoInterseccionadoAnterior) {
            const datosPrevios = mapaDatosObjeto.get(
              objetoInterseccionadoAnterior.id,
            );
            if (datosPrevios && datosPrevios.esGrupoComplejo) {
              datosPrevios.componenteColor.material.color.setHex(
                datosPrevios.colorOriginal,
              );
              datosPrevios.componenteColor.material.emissive.setHex(0x000000);
            }
          }

          objetoInterseccionadoAnterior = objetoActual;
          const datos = mapaDatosObjeto.get(objetoActual.id);

          if (datos && datos.esGrupoComplejo) {
            datos.componenteColor.material.emissive.setHex(0x223344);
            container!.style.cursor = "pointer";

            tooltip!.innerHTML = `
              <div class="text-white font-bold">${datos.nombre}</div>
              <div class="text-slate-400 text-[10px] mt-0.5 uppercase tracking-wider font-mono">${datos.tipo}</div>
              <div class="text-emerald-400 text-[10px] mt-1 font-medium">➔ Clic para abrir planos</div>
            `;
            tooltip!.style.display = "block";
          }
        }
      } else {
        if (objetoInterseccionadoAnterior) {
          const datosPrevios = mapaDatosObjeto.get(
            objetoInterseccionadoAnterior.id,
          );
          if (datosPrevios && datosPrevios.esGrupoComplejo) {
            datosPrevios.componenteColor.material.color.setHex(
              datosPrevios.colorOriginal,
            );
            datosPrevios.componenteColor.material.emissive.setHex(0x000000);
          }
          objetoInterseccionadoAnterior = null;
          container!.style.cursor = "grab";
          tooltip!.style.display = "none";
        }
      }

      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener("resize", () => {
      const w = container.clientWidth;
      const h = container.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });
  }

  initThreeJS();
</script>
