---
import fs from 'node:fs';
import path from 'node:path';
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return [
    { params: { linea: 'pe-17' } },
    { params: { linea: 'pe-24' } },
    { params: { linea: 'pe-26' } },
  ];
}

const { linea } = Astro.params;
const codigoLineaUpper = linea.toUpperCase();

// 1. DICCIONARIO ÚNICO DE COORDENADAS POR ESTACIÓN
const CONFIG_MAPAS: Record<string, Record<string, { x: number; y: number }>> = {
  "PE-17": {
    "El Priorato":                                    { x: 85, y: 10 },
    "Lora del Río":                                   { x: 78, y: 16 },
    "Guadañoz":                                       { x: 71, y: 22 },
    "Los Rosales":                                    { x: 64, y: 28 },
    "Brenes":                                         { x: 57, y: 34 },
    "Majarabique":                                    { x: 50, y: 40 },
    "Apd. S. Jerónimo - Apd. Estadio - Apd. Cartuja": { x: 38, y: 52 },
    "Triángulo Tamarguillo":                          { x: 50, y: 52 },
    "C.T.T. Sevilla":                                 { x: 44, y: 64 },
    "Sevilla Santa Justa":                            { x: 38, y: 74 },
    "La Negrilla":                                    { x: 58, y: 68 }
  },
  "PE-24": {
    "Sevilla Santa Justa":      { x: 50, y: 8 },
    "La Salud":                 { x: 50, y: 16 },
    "Dos Hermanas":             { x: 50, y: 24 },
    "Utrera":                   { x: 50, y: 32 },
    "Las Alcantarillas":        { x: 46, y: 38 },
    "Las Cabezas":              { x: 42, y: 44 },
    "Lebrija":                  { x: 38, y: 50 },
    "Aeropuerto de Jerez":      { x: 34, y: 56 },
    "Jerez-Mercancías":         { x: 30, y: 62 },
    "Jerez de la Frontera":     { x: 26, y: 68 },
    "El Puerto de Santa María": { x: 26, y: 76 },
    "Las Aletas":               { x: 26, y: 82 },
    "Puerto Real":              { x: 26, y: 88 },
    "San Fernando-Bahía Sur":   { x: 18, y: 92 },
    "Cortadura":                { x: 12, y: 84 },
    "Cádiz":                    { x: 12, y: 74 }
  },
  "PE-26": {
    "Majarabique":                                    { x: 92, y: 25 },
    "Alamillo":                                       { x: 84, y: 27 },
    "Apd. S. Jerónimo-Apd. Estadio-Apd. Cartuja":     { x: 88, y: 39 },
    "Valencina-Santiponce":                           { x: 76, y: 29 },
    "Salteras":                                       { x: 69, y: 33 },
    "Villanueva-Olivares":                            { x: 62, y: 36 },
    "Benacazón":                                      { x: 55, y: 40 },
    "Aznalcázar-Pilas":                               { x: 48, y: 44 },
    "Huévar":                                         { x: 42, y: 47 },
    "Carrión de los Céspedes":                        { x: 36, y: 49 },
    "Escacena":                                       { x: 30, y: 51 },
    "Villalba":                                       { x: 24, y: 53 },
    "La Palma del Condado":                           { x: 19, y: 56 },
    "Niebla":                                         { x: 14, y: 60 },
    "San Juan del Puerto":                            { x: 10, y: 66 },
    "Huelva Mercancías":                              { x: 8, y: 73 },
    "Huelva":                                         { x: 8, y: 84 }
  }
};

const TRAMOS_VIAS: Record<string, string[][]> = {
  "pe-17": [
    ["El Priorato", "Lora del Río", "Guadañoz", "Los Rosales", "Brenes", "Majarabique"],
    ["Majarabique", "Apd. S. Jerónimo - Apd. Estadio - Apd. Cartuja"],
    ["Majarabique", "Triángulo Tamarguillo"],
    ["Triángulo Tamarguillo", "C.T.T. Sevilla", "Sevilla Santa Justa"],
    ["Triángulo Tamarguillo", "La Negrilla"]
  ],
  "pe-24": [
    ["Sevilla Santa Justa", "La Salud", "Dos Hermanas", "Utrera", "Las Alcantarillas", "Las Cabezas", "Lebrija", "Aeropuerto de Jerez", "Jerez-Mercancías", "Jerez de la Frontera", "El Puerto de Santa María", "Las Aletas", "Puerto Real", "San Fernando-Bahía Sur", "Cortadura", "Cádiz"]
  ],
  "pe-26": [
    ["Majarabique", "Alamillo", "Valencina-Santiponce", "Salteras", "Villanueva-Olivares", "Benacazón", "Aznalcázar-Pilas", "Huévar", "Carrión de los Céspedes", "Escacena", "Villalba", "La Palma del Condado", "Niebla", "San Juan del Puerto", "Huelva Mercancías", "Huelva"],
    ["Alamillo", "Apd. S. Jerónimo-Apd. Estadio-Apd. Cartuja"]
  ]
};

const coordMapa = CONFIG_MAPAS[codigoLineaUpper] || {};
const tramosDeEstaLinea = TRAMOS_VIAS[linea] || [];
const estacionesUnicas = [...new Set(tramosDeEstaLinea.flat())];

const limpiarParaMatch = (str: string) => {
  return str.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9]/g, "");
};

const docsDir = path.join(process.cwd(), 'public', 'docs', 'Consignas finales');
const subestacionesDetectadas = new Set<string>();

if (fs.existsSync(docsDir)) {
  const allFiles = fs.readdirSync(docsDir, { recursive: true }) as string[];
  allFiles.forEach(file => {
    const normPath = file.replace(/\\/g, '/');
    if (normPath.toLowerCase().startsWith(linea.toLowerCase() + '/')) {
      const fileName = normPath.split('/').pop() || '';
      if (fileName.toLowerCase().includes('s.e.') || fileName.toLowerCase().includes('subestacion')) {
        subestacionesDetectadas.add(limpiarParaMatch(fileName));
      }
    }
  });
}

const nodosMapa = estacionesUnicas.map((nombre) => {
  const coords = coordMapa[nombre] || { x: 50, y: 50 };
  const tokenEstacion = limpiarParaMatch(nombre);
  let tieneSub = false;

  subestacionesDetectadas.forEach(subToken => {
    if (subToken.includes(tokenEstacion) || tokenEstacion.includes(subToken)) tieneSub = true;
  });

  if (["Dos Hermanas", "Lebrija", "Cortadura", "Lora del Río", "Sevilla Santa Justa"].includes(nombre)) {
    tieneSub = true; 
  }

  return {
    nombre,
    x: coords.x * 15,
    y: coords.y * 7,
    tieneSub
  };
});

// ===================================================
// CALCULO DE ENCUADRE DINÁMICO (BOUNDING BOX)
// ===================================================
const xValores = nodosMapa.map(n => n.x);
const yValores = nodosMapa.map(n => n.y);

const minX = Math.min(...xValores);
const maxX = Math.max(...xValores);
const minY = Math.min(...yValores);
const maxY = Math.max(...yValores);

// Padding perimetral para evitar que las etiquetas de texto queden cortadas en los bordes
const padding = 65;

const viewBoxX = minX - padding;
const viewBoxY = minY - padding;
const viewBoxWidth = (maxX - minX) + (padding * 2);
const viewBoxHeight = (maxY - minY) + (padding * 2);

// Evitamos colapsos de dimensiones a cero si la línea tiene pocos nodos
const finalWidth = Math.max(viewBoxWidth, 600);
const finalHeight = Math.max(viewBoxHeight, 350);
---

<html lang="es" class="h-full">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Mapa de Línea - {codigoLineaUpper}</title>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col font-sans">
    
    <Header lineaActiva={linea} />
<main class="max-w-[1600px] mx-auto p-4 md:p-8 w-full flex-1 flex flex-col min-h-0">
      
      <!-- ENCABEZADO DE LÍNEA COMPACTO -->
      <div class="flex items-center gap-4 mb-6 border-b border-slate-800 pb-4 shrink-0">
        <span class="text-xs font-mono uppercase bg-emerald-950 text-emerald-300 border border-emerald-800/80 px-3 py-1 rounded font-bold">
          {codigoLineaUpper}
        </span>
        <h1 class="text-xl font-bold tracking-tight text-white">Consola de Control e Infraestructura</h1>
      </div>

      <!-- INTERFAZ SPLIT: DOS COLUMNAS REORGANIZADAS -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 flex-1 items-stretch min-h-0">
        
        <!-- PANEL LATERAL IZQUIERDO: INFORMACIÓN Y ACCESOS (Ocupa 4 de 12 columnas) -->
        <div class="lg:col-span-4 flex flex-col gap-4">
          
          <!-- Bloque de Contexto Técnico -->
          <div class="bg-slate-900 border border-slate-800 rounded-2xl p-5 shadow-xl">
            <h2 class="text-xs font-bold uppercase text-slate-400 tracking-widest mb-1">Panel Operativo</h2>
            <p class="text-xs text-slate-500 leading-relaxed">
              Esquema geométrico interactivo de la infraestructura ferroviaria de la línea. Selecciona cualquier nodo directamente en el mapa para acceder a la gestión de consignas finales y planos de electrificación de la estación.
            </p>
          </div>

          <!-- Listado Técnico de Estaciones del Trazado -->
          <div class="bg-slate-900 border border-slate-800 rounded-2xl p-5 shadow-xl flex-1 flex flex-col min-h-[250px] lg:min-h-0 overflow-hidden">
            <h3 class="text-xs font-bold uppercase text-slate-400 tracking-widest border-b border-slate-800 pb-2 mb-3 shrink-0">
              Índice Secuencial de Nodos
            </h3>
            
            <div class="overflow-y-auto pr-1 flex-1 space-y-1 custom-scrollbar">
              {nodosMapa.map((nodo) => {
                const slugEstacion = nodo.nombre
                  .toLowerCase()
                  .replace(/\./g, '')
                  .replace(/[\s\-]+/g, '-')
                  .replace(/[^a-z0-9\-áéíóúñ]/g, '');

                return (
                  <a
                    href={`/${linea}/${slugEstacion}`}
                    class="flex items-center justify-between p-2 rounded-lg bg-slate-950/40 hover:bg-slate-800/60 border border-slate-900 hover:border-slate-700/60 group transition-all text-xs"
                  >
                    <div class="flex items-center gap-2">
                      <span class={`w-2 h-2 rounded-full ${nodo.tieneSub ? 'bg-amber-500' : 'bg-cyan-500'}`}></span>
                      <span class="text-slate-300 group-hover:text-white font-medium transition-colors">{nodo.nombre}</span>
                    </div>
                    <span class="text-[10px] font-mono text-slate-600 group-hover:text-slate-400 transition-colors uppercase">
                      {nodo.tieneSub ? 'S/E' : 'Estación'} →
                    </span>
                  </a>
                );
              })}
            </div>
          </div>
        </div>

        <!-- PANEL DERECHO: VISOR DEL MAPA INTEGRADO (Ocupa 8 de 12 columnas) -->
        <div class="lg:col-span-8 bg-slate-900 border border-slate-800 rounded-2xl p-4 flex flex-col justify-center items-center shadow-2xl relative min-h-[450px] lg:min-h-0 overflow-hidden">
          
          <!-- Leyenda flotante en la esquina del mapa para hacerlo más pro -->
          <div class="absolute top-4 left-4 bg-slate-950/80 backdrop-blur-md border border-slate-800 px-3 py-2 rounded-xl flex gap-4 text-[10px] text-slate-400 z-10 font-medium">
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-cyan-500"></span> Estación Común
            </div>
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-amber-500"></span> Subestación (S/E)
            </div>
          </div>

          <!-- Contenedor del SVG elástico que elimina los márgenes muertos -->
          <div class="w-full h-full flex items-center justify-center p-2">
            <svg 
              class="w-auto h-auto max-w-full max-h-[60vh] lg:max-h-[68vh] transition-all duration-300 drop-shadow-[0_0_25px_rgba(6,182,212,0.05)]" 
              viewBox={`${viewBoxX} ${viewBoxY} ${finalWidth} ${finalHeight}`}
              preserveAspectRatio="xMidYMid meet"
            >
              <defs>
                <linearGradient id="railGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#10b981" />
                  <stop offset="50%" stop-color="#06b6d4" />
                  <stop offset="100%" stop-color="#f59e0b" />
                </linearGradient>
              </defs>

              {/* TRAMOS DE VÍAS */}
              {tramosDeEstaLinea.map((tramo) => {
                const pointsStr = tramo.map((nombreEst, idx) => {
                  if (linea === "pe-26" && tramo.includes("Apd. S. Jerónimo-Apd. Estadio-Apd. Cartuja") && idx === 0) {
                    const m = coordMapa["Majarabique"] || { x: 92, y: 25 };
                    const a = coordMapa["Alamillo"] || { x: 84, y: 27 };
                    const midX = (m.x + a.x) / 2;
                    const midY = (m.y + a.y) / 2;
                    return `${midX * 15},${midY * 7}`;
                  }
                  const coords = coordMapa[nombreEst] || { x: 50, y: 50 };
                  return `${coords.x * 15},${coords.y * 7}`;
                }).join(' ');

                return (
                  <g>
                    <polyline points={pointsStr} fill="none" stroke="#1e293b" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
                    <polyline points={pointsStr} fill="none" stroke="url(#railGradient)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                  </g>
                );
              })}

              {/* NODOS INTERACTIVOS */}
              {nodosMapa.map((nodo) => {
                const slugEstacion = nodo.nombre
                  .toLowerCase()
                  .replace(/\./g, '')
                  .replace(/[\s\-]+/g, '-')
                  .replace(/[^a-z0-9\-áéíóúñ]/g, '');

                return (
                  <g class="cursor-pointer group select-none" onclick={`window.location.href = '/${linea}/${slugEstacion}'`}>
                    <circle cx={nodo.x} cy={nodo.y} r="14" fill="#06b6d4" class="opacity-0 group-hover:opacity-10 transition-all duration-150" />
                    <circle cx={nodo.x} cy={nodo.y} r="7" fill="#020617" stroke={nodo.tieneSub ? "#f59e0b" : "#06b6d4"} stroke-width="2.5" class="group-hover:stroke-white transition-all duration-150" />
                    <circle cx={nodo.x} cy={nodo.y} r="2.5" fill={nodo.tieneSub ? "#f59e0b" : "#06b6d4"} />
                    
                    <text 
                      x={nodo.x + 12} 
                      y={nodo.y + 3} 
                      text-anchor="start" 
                      class="fill-slate-400 font-sans font-medium text-[9px] group-hover:fill-white transition-colors duration-100"
                    >
                      {nodo.nombre}
                    </text>
                  </g>
                );
              })}
            </svg>
          </div>

        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>