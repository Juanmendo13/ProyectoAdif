---
import fs from 'node:fs';
import path from 'node:path';
import '../../styles/global.css';

// Generación estática combinada de Línea + Estación para el build de Vercel
export function getStaticPaths() {
  // Mapeo exacto de los nombres que generan los archivos físicos
  const estacionesPorLinea: Record<string, string[]> = {
    "pe-17": ["el-priorato", "lora-del-río", "guadañoz", "los-rosales", "brenes", "majarabique", "triángulo-tamarguillo", "la-negrilla", "c.t.t.-sevilla", "apd.-s.-jerónimo---apd.-estadio---apd.-cartuja", "sevilla-santa-justa"],
    "pe-24": ["sevilla-santa-justa", "la-salud", "dos-hermanas", "utrera", "las-alcantarillas", "las-cabezas", "lebrija", "aeropuerto-de-jerez", "jerez-mercancías", "jerez-de-la-frontera", "el-puerto-de-santa-maría", "las-aletas", "puerto-real", "san-fernando-bahía-sur", "cortadura", "cádiz"],
    "pe-26": ["majarabique", "alamillo", "apd.-s.-jerónimo-apd.-estadio-apd.-cartuja", "valencina-santiponce", "salteras", "villanueva-olivares", "benacazón", "aznalcázar-pilas", "huévar", "carrión-de-los-céspedes", "escacena", "villalba", "la-palma-del-condado", "niebla", "san-juan-del-puerto", "huelva-mercancías", "huelva"]
  };

  const paths: any[] = [];
  Object.entries(estacionesPorLinea).forEach(([linea, estaciones]) => {
    estaciones.forEach((estacion) => {
      paths.push({ params: { linea, estacion } });
    });
  });
  return paths;
}

const { linea, estacion } = Astro.params;

// Re-convertir el slug de la URL a un nombre legible
const nombreLegible = estacion.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());

// Buscar los ficheros específicos de esta estación
const docsDir = path.join(process.cwd(), 'public', 'docs', 'Consignas finales');
let esquemaUrl = null;
let subestacionUrl = null;

if (fs.existsSync(docsDir)) {
  const allFiles = fs.readdirSync(docsDir, { recursive: true }) as string[];
  
  allFiles.forEach(file => {
    const norm = file.replace(/\\/g, '/');
    const lower = norm.toLowerCase();
    
    // Verificamos si pertenece a la línea y al slug de la estación
    if (lower.startsWith(linea + '/') && lower.includes(estacion)) {
      const url = `/docs/Consignas finales/${norm}`;
      if (lower.includes('s.e.') || lower.includes('subestacion')) {
        subestacionUrl = url;
      } else {
        esquemaUrl = url;
      }
    }
  });
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{nombreLegible} - Dashboard Estación</title>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen font-sans">
    <main class="max-w-[1200px] mx-auto p-8 lg:p-12 w-full">
      
      <a href={`/${linea}`} class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-white mb-8 transition-colors group">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 group-hover:-translate-x-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
        Volver al esquema de línea
      </a>

      <!-- ENCABEZADO DE ESTACIÓN -->
      <div class="bg-slate-900 border border-slate-800 rounded-3xl p-8 mb-8 shadow-xl">
        <span class="text-xs font-mono uppercase bg-emerald-950 text-emerald-400 border border-emerald-800 px-3 py-1 rounded-full">{linea.toUpperCase()}</span>
        <h1 class="text-4xl font-black text-white mt-4 tracking-tight capitalize">{nombreLegible}</h1>
        <p class="text-slate-400 text-sm mt-1">Espacio de gestión técnica de instalaciones y sistemas asociados.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- SECCIÓN IZQUIERDA: DOCUMENTACIÓN EXISTENTE -->
        <div class="md:col-span-1 flex flex-col gap-4">
          <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-md">
            <h2 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">Planos de Electrificación</h2>
            
            <div class="flex flex-col gap-3">
              {esquemaUrl ? (
                <a href={esquemaUrl} target="_blank" class="w-full bg-slate-950 hover:bg-sky-900/20 text-sky-400 py-3 px-4 rounded-xl border border-slate-800 hover:border-sky-900/60 transition-all flex items-center justify-between font-medium text-xs">
                  <span>Esquema de Estación</span>
                  <span class="font-mono opacity-50">PDF</span>
                </a>
              ) : (
                <p class="text-xs text-slate-600 italic">No hay planos de estación cargados.</p>
              )}

              {subestacionUrl ? (
                <a href={subestacionUrl} target="_blank" class="w-full bg-slate-950 hover:bg-amber-900/20 text-amber-400 py-3 px-4 rounded-xl border border-slate-800 hover:border-amber-900/60 transition-all flex items-center justify-between font-medium text-xs">
                  <span>Subestación de Tracción</span>
                  <span class="font-mono opacity-50">PDF</span>
                </a>
              ) : (
                <p class="text-xs text-slate-600 italic">No dispone de Subestación (S/E).</p>
              )}
            </div>
          </div>
        </div>

        <!-- SECCIÓN DERECHA: PROCESO DE EXPANSIÓN FUTURA -->
        <div class="md:col-span-2 bg-slate-900 border border-slate-800 border-dashed rounded-2xl p-8 flex flex-col justify-center items-center text-center">
          <div class="w-12 h-12 bg-slate-950 rounded-xl border border-slate-800 flex items-center justify-center text-slate-500 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
          </div>
          <h3 class="text-slate-300 font-bold mb-1">Módulo de Datos de Estación</h3>
          <p class="text-slate-500 text-xs max-w-sm leading-relaxed">
            Aquí podrás integrar próximamente telemedidas en tiempo real, histórico de alarmas de enclavamientos o fichas de mantenimiento de catenaria.
          </p>
        </div>
      </div>

    </main>
  </body>
</html>