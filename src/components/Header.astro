---
const { lineaActiva } = Astro.props;
---
<header class="sticky top-0 z-50 w-full border-b border-slate-800 bg-slate-950/80 backdrop-blur-md shadow-lg">
  <div class="max-w-[1600px] mx-auto px-8 h-20 flex items-center justify-between">
    
    <!-- Bloque Izquierdo: Botón Volver + Logo -->
    <div class="flex items-center gap-6">
      {lineaActiva && (
        <>
          <a 
            href="/" 
            class="flex items-center gap-2 text-sm font-bold text-slate-200 hover:text-emerald-400 transition-colors group py-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-emerald-400 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            <span class="font-sans">Volver</span>
          </a>
          <div class="w-px h-6 bg-slate-800"></div>
        </>
      )}

      <div class="flex items-center gap-3">
        <div class="w-3.5 h-3.5 rounded-full bg-emerald-500 animate-pulse"></div>
        <span class="font-mono text-xs tracking-widest text-slate-400 uppercase hidden md:inline">Sistemas Adif</span>
        <span class="text-slate-600 font-light hidden md:inline">|</span>
        <a href="/" class="font-sans font-bold text-base tracking-tight text-white hover:text-emerald-400 transition-colors">
          ProyectoAdif <span class="text-xs text-emerald-400 font-mono font-normal">v1.2</span>
        </a>
      </div>
    </div>

    <!-- Navegación de Líneas: Color de Letra Fijo -->
    <nav class="flex items-center gap-2 font-mono text-sm">
      {[
        { 
          id: 'pe-17', 
          label: 'PE-17', 
          textColor: 'text-emerald-400 hover:bg-emerald-950/30',
          activeBg: 'bg-emerald-950/80 border-emerald-700/80 shadow-md'
        },
        { 
          id: 'pe-24', 
          label: 'PE-24', 
          textColor: 'text-cyan-400 hover:bg-cyan-950/30',
          activeBg: 'bg-cyan-950/80 border-cyan-700/80 shadow-md'
        },
        { 
          id: 'pe-26', 
          label: 'PE-26', 
          textColor: 'text-amber-500 hover:bg-amber-950/30',
          activeBg: 'bg-amber-950/80 border-amber-700/80 shadow-md'
        }
      ].map((l) => (
        <a
          href={`/${l.id}`}
          class={`px-4 py-2 rounded-lg transition-all duration-150 border text-center min-w-[75px] font-bold ${l.textColor} ${
            lineaActiva === l.id
              ? `${l.activeBg}`
              : 'border-transparent'
          }`}
        >
          {l.label}
        </a>
      ))}
    </nav>
  </div>
</header>